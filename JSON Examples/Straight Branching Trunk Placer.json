{ //This is an example of how to use the Straight Branching Trunk Placer (Original is from Into the Woods)
  "type": "minecraft:tree",
  "config": {
    "dirt_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "minecraft:rooted_dirt"
      }
    },
    "foliage_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "into_the_woods:lofty_leaves",
        "Properties": {
          "distance": "7",
          "persistent": "false",
          "waterlogged": "false"
        }
      }
    },
    "trunk_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "into_the_woods:lofty_log",
        "Properties": {
          "axis": "y"
        }
      }
    },
    "force_dirt": false,
    "ignore_vines": true,
    "foliage_placer": {
      "type": "minecraft:random_spread_foliage_placer",
      "radius": 2,
      "offset": 2,
      "foliage_height": 2,
      "leaf_placement_attempts": 54
    },
    "trunk_placer": {
      "type": "ebonylib:straight_branching_trunk_placer",
      "base_height": 2,
      "height_rand_a": 1,
      "height_rand_b": 1, //Base Height parameters are the same as normal trees.
      "start_height": 2, //Flat value that determines how many blocks above the bottom that branches can generate.
      "top_height": 1, //Flat value that determines how many blocks below the top that branches can generate.
      "branch_chance": 0.75, //Chance of branches generating (Evaluated for every log of the trunk above the start height and below the top height)
      "branch_length_min": 1,
      "branch_length_max": 1 //Min and max values for the length of branches.
    },
    "minimum_size": {
      "type": "minecraft:two_layers_feature_size",
      "limit": 2,
      "lower_size": 0,
      "upper_size": 2
    },
    "decorators": [
      {
        "type": "minecraft:beehive",
        "probability": 0.03
      }
    ]
  }
}
