{ //This is an example of how to use the Chandelier Branching Trunk Placer (Original is from Into the Woods)
  "type": "minecraft:tree",
  "config": {
    "dirt_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "minecraft:dirt"
      }
    },
    "foliage_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "into_the_woods:oldknot_leaves"
      }
    },
    "trunk_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "into_the_woods:oldknot_log"
      }
    },
    "force_dirt": false,
    "ignore_vines": true,
    "foliage_placer": {
      "type": "minecraft:random_spread_foliage_placer",
      "radius": 3,
      "offset": 0,
      "foliage_height": 2,
      "leaf_placement_attempts": 87
    },
    "trunk_placer": {
      "type": "ebonylib:chandelier_branching_trunk_placer",
      "base_height": 7,
      "height_rand_a": 8,
      "height_rand_b": 2, //Base Height parameters are the same as normal trees.
      "branch_start_min": 3,
      "branch_start_max": 5, //Min and max height above the bottom of the trunk that branches can place
      "branch_length_min": 10,
      "branch_length_max": 16, //Min and max length of each induvidual branch. Small branches are not affected by this.
      "small_branch_length_min": 2,
      "small_branch_length_max": 2, //Min and max length of small branches. These extend outwards in the same direction as the big branch they are attached to.
      "small_branch_chance": 0.25, //Chance of small branches generating (Evaluated for every log on a branch)
      "branch_end_max": 0 //How many blocks below the top of the main tree trunk that branches can generate.
    },
    "minimum_size": {
      "type": "minecraft:two_layers_feature_size",
      "limit": 1,
      "lower_size": 0,
      "upper_size": 1
    },
    "decorators": []
  }
}
