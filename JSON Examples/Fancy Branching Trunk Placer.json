{ //This is an example of how to use the Fancy Branching Trunk Placer (Original is from Into the Woods)
  "type": "minecraft:tree",
  "config": {
    "dirt_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "into_the_woods:dark_sandstone"
      }
    },
    "foliage_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "into_the_woods:oasis_palm_leaves"
      }
    },
    "trunk_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "into_the_woods:oasis_palm_log"
      }
    },
    "force_dirt": true,
    "ignore_vines": true,
    "foliage_placer": {
      "type": "minecraft:acacia_foliage_placer",
      "radius": 3,
      "offset": 0
    },
    "trunk_placer": {
      "type": "ebonylib:fancy_branching_trunk_placer",
      "base_height": 4,
      "height_rand_a": 3,
      "height_rand_b": 5, //Base Height parameters are the same as normal trees.
  	  "branch_start_min": 2,
  	  "branch_start_max": 4, //Min and max height above the bottom of the trunk that branches can place
  	  "branch_end_max": 1, //How many blocks below the top of the main tree trunk that branches can generate.
  	  "branch_length_min": 3,
  	  "branch_length_max": 6, //Min and max length of each induvidual branch. Small branches are not affected by this.
  	  "small_branch_length_min": 1,
  	  "small_branch_length_max": 2, //Min and max length of small branches. These extend outwards in a random direction from the main branch.
  	  "small_branch_chance": 0.1, //Chance of small branches generating (Evaluated for every log on a branch)
  	  "trunk_bend_chance": 0.1, //Chance of the trunk offsetting itself by one block. Evaluated for every trunk block.
  	  "branch_tilt_chance": 0.6, //Chance of a branch moving upwards by one block.
  	  "small_branch_tilt_chance": 0.8, //Chance of a small branch moving upwards by one block.
      "branch_chance": 0.55 //Chance of branches generating (Evaluated for every log of the trunk above the start height and below the top height)
    },
    "minimum_size": {
      "type": "minecraft:two_layers_feature_size",
      "limit": 1,
      "lower_size": 0,
      "upper_size": 2
    },
    "decorators": []
  }
}
